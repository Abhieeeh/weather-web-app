<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather Dashboard</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/weather.css">
</head>
<body>

<div class="overlay"></div>

<div class="container d-flex flex-column flex-md-row justify-content-center align-items-center gap-3 w-100">
  
  <!-- Left Side: Current Weather -->
  <div class="weather-card">
    <div class="search-container">
      <form action="/result" method="POST" class="m-0 position-relative">
        <i class="bi bi-geo-alt-fill search-icon-form"></i>
        <input type="text" id="city" name="city" class="form-control search-input" placeholder="Enter city name" required>
        <button type="submit" class="search-btn" aria-label="Search">
            <i class="bi bi-search" style="font-weight: bold; font-size: 1rem;"></i>
        </button>
      </form>
    </div>

    <div class="weather-info">
      <div class="imgtext">
        <i class="bi bi-cloud-sun-fill weather-icon-main"></i>
        <h2 class="city"><%=Cityname%></h2>
      </div>
      <h1 class="temp"><%=tempindegree%></h1>
    </div>
    
    <div class="details-grid">
      <div class="detail-item">
        <i class="bi bi-droplet-half detail-icon" style="color:#00C9FF;"></i>
        <span class="detail-label">Humidity</span>
        <div class="detail-value"><%=humidpercent%></div>
      </div>
      <div class="detail-item">
        <i class="bi bi-wind detail-icon" style="color:#92FE9D;"></i>
        <span class="detail-label">Wind</span>
        <div class="detail-value"><%=windspeed%></div>
      </div>
      <div class="detail-item">
        <i class="bi bi-thermometer-half detail-icon" style="color:#ff7e5f;"></i>
        <span class="detail-label">Feels Like</span>
        <div class="detail-value"><%=feelslike%></div>
      </div>
      <div class="detail-item">
        <i class="bi bi-speedometer2 detail-icon" style="color:#f0ad4e;"></i>
        <span class="detail-label">Pressure</span>
        <div class="detail-value"><%=pressure%></div>
      </div>
    </div>
  </div>

  <!-- Right Side: 5-Day Forecast -->
  <% if(forecastArray && forecastArray.length > 0) { %>
  <div class="weather-card" style="max-width: 320px;">
    <h4 class="mb-3 fw-semibold text-center pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.2); font-size: 1.1rem;">5-Day Forecast</h4>
    <div class="forecast-list d-flex flex-column gap-2">
      <% forecastArray.forEach(function(dayInfo) { %>
        <div class="forecast-item d-flex justify-content-between align-items-center px-3 py-2 rounded-3" style="background: rgba(0,0,0,0.15);">
          <span class="fs-6 fw-medium" style="width: 45px;"><%= dayInfo.day %></span>
          <div class="d-flex align-items-center">
             <% if(dayInfo.weather === 'Clear') { %>
                <i class="bi bi-sun-fill text-warning fs-4"></i>
             <% } else if(dayInfo.weather === 'Clouds') { %>
                <i class="bi bi-cloud-fill text-light fs-4"></i>
             <% } else if(dayInfo.weather === 'Rain' || dayInfo.weather === 'Drizzle') { %>
                <i class="bi bi-cloud-rain-fill text-info fs-4"></i>
             <% } else if(dayInfo.weather === 'Thunderstorm') { %>
                <i class="bi bi-cloud-lightning-rain-fill text-warning fs-4"></i>
             <% } else if(dayInfo.weather === 'Snow') { %>
                <i class="bi bi-snow text-white fs-4"></i>
             <% } else { %>
                <i class="bi bi-cloud-haze-fill text-secondary fs-4"></i>
             <% } %>
          </div>
          <span class="fs-6 fw-bold" style="width: 70px; text-align: right;"><%= dayInfo.temp %></span>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>